NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_arch_render
DB_USER=postgres
DB_PASSWORD=123456
DB_SSL=false
DB_MAX_POOL_SIZE=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000
MOCK_RENDER_DELAY_MS=5000
AI_PROVIDER=302AI
AI_BASE_URL=https://api.302.ai
AI_API_KEY=Bearer <your-302ai-api-key>
IMAGE_MODEL=gemini-2.5-flash-image
AI_REQUEST_TIMEOUT_MS=30000
AI_POLL_INTERVAL_MS=3000
AI_POLL_ATTEMPTS=20
