NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Railway and other managed Postgres providers can use a single URL.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_arch_render
DB_USER=postgres
DB_PASSWORD=123456
# Set DB_SSL=true for Railway or when your provider requires SSL.
DB_SSL=false
DB_MAX_POOL_SIZE=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000
MOCK_RENDER_DELAY_MS=5000
CORS_ALLOWED_ORIGINS=http://localhost:3001
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_HEADERS=Content-Type, Authorization
AI_PROVIDER=302AI
AI_BASE_URL=https://api.302.ai
AI_API_KEY=Bearer <your-302ai-api-key>
IMAGE_MODEL=flux-2-max
PROMPT_MODEL=qwen3.5-27b
GEOMETRY_MODEL=
AI_REQUEST_TIMEOUT_MS=30000
PROMPT_REQUEST_TIMEOUT_MS=60000
GEOMETRY_REQUEST_TIMEOUT_MS=15000
AI_POLL_INTERVAL_MS=3000
AI_POLL_ATTEMPTS=20
